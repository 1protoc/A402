RUST_LOG=info

# TEE platform selection
A402_TEE_PLATFORM=sev-snp
A402_ATTESTATION_PROTOCOL=a402-svm-v1

# Base64 AMD SEV-SNP report. Production collectors should generate this inside
# the SNP guest and bind the TLS public key hash into REPORT_DATA.
A402_SEV_SNP_ATTESTATION_REPORT_B64=<base64_snp_report>

# Canonical policy inputs used to derive attestationPolicyHash when
# A402_ATTESTATION_POLICY_HASH_HEX is not set.
A402_SEV_SNP_MEASUREMENT_HEX=<launch_measurement_hex>
# Optional policy fields:
# A402_SEV_SNP_HOST_DATA_HEX=<host_data_hex>
# A402_SEV_SNP_REPORT_DATA_HEX=<report_data_hex>
# A402_SEV_SNP_FAMILY_ID_HEX=<family_id_hex>
# A402_SEV_SNP_IMAGE_ID_HEX=<image_id_hex>
# A402_SEV_SNP_POLICY_HEX=<snp_policy_hex>
# A402_SEV_SNP_VMPL=0

# On-chain runtime
A402_PROGRAM_ID=<devnet_program_id>
A402_VAULT_CONFIG=<vault_config_pubkey>
A402_VAULT_TOKEN_ACCOUNT=<vault_token_account_pubkey>
A402_USDC_MINT=<devnet_usdc_mint>
A402_SOLANA_RPC_URL=<devnet_rpc_url>
A402_SOLANA_WS_URL=<devnet_ws_url>

# Multichain adapters, optional
# A402_EVM_RPC_URL=
# A402_EVM_SETTLEMENT_CONTRACT=
# A402_EVM_SUBMITTER=
# A402_BITCOIN_RPC_URL=
# A402_BITCOIN_RPC_USER=
# A402_BITCOIN_RPC_PASSWORD=

# Bootstrap secrets. For real SNP deployments, prefer an SNP-attested KMS or
# measured secret-injection flow. These direct env vars are for lab/dev only.
A402_VAULT_SIGNER_SECRET_KEY_B64=<base64_64_byte_ed25519_keypair_or_32_byte_seed>
A402_STORAGE_KEY_B64=<base64_32_byte_storage_key>

# Local durable state inside the confidential VM. Use encrypted block storage
# or remote encrypted object storage depending on deployment requirements.
A402_WAL_PATH=/var/lib/a402/wal.jsonl
A402_WATCHTOWER_URL=http://127.0.0.1:3200

# TLS terminates inside the SEV-SNP guest.
A402_ENCLAVE_TLS_CERT_PATH=/etc/a402/tls/server.crt
A402_ENCLAVE_TLS_KEY_PATH=/etc/a402/tls/server.key
# Optional mTLS:
# A402_ENCLAVE_TLS_CLIENT_CA_PATH=/etc/a402/tls/client-ca.crt

# Batch privacy defaults
A402_BATCH_WINDOW_SEC=120
A402_MIN_BATCH_PROVIDERS=2
A402_MIN_ANONYMITY_WINDOW_SEC=300
A402_AUTO_BATCH_MIN_PROVIDER_PAYOUT_ATOMIC=1000000
A402_ALLOW_ADMIN_PRIVACY_BYPASS_BATCH=0

# Keep control-plane APIs disabled for public deployments.
A402_ENABLE_PROVIDER_REGISTRATION_API=0
A402_ENABLE_ADMIN_API=0
