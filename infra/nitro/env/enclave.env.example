RUST_LOG=info

# Nitro parent/enclave wiring
A402_ENCLAVE_INTERCONNECT_MODE=vsock
A402_PARENT_CID=3
A402_ENCLAVE_INGRESS_PORT=5000
A402_ENCLAVE_EGRESS_PORT=5001
A402_ENCLAVE_KMS_PORT=5002
A402_ENCLAVE_SNAPSHOT_PORT=5003

# On-chain runtime
A402_PROGRAM_ID=<devnet_program_id>
A402_VAULT_CONFIG=<vault_config_pubkey>
A402_VAULT_TOKEN_ACCOUNT=<vault_token_account_pubkey>
A402_USDC_MINT=<devnet_usdc_mint>
A402_SOLANA_RPC_URL=<devnet_rpc_url>
A402_SOLANA_WS_URL=<devnet_ws_url>

# Parent-accessible durable state
A402_WAL_PATH=/var/lib/a402/wal-devnet.jsonl
A402_WAL_PREFIX=wal/<vault_config_pubkey>
A402_WATCHTOWER_URL=http://127.0.0.1:3200
A402_SNAPSHOT_DATA_KEY_ID=<kms_key_arn_or_alias>
A402_STORAGE_KEY_METADATA_KEY=meta/<vault_config_pubkey>/snapshot-data-key.ciphertext

# Nitro-sealed bootstrap
A402_VAULT_SIGNER_SEED_CIPHERTEXT_B64=<kms_ciphertext_blob_base64>
A402_KMS_KEY_ARN_SHA256=<sha256_of_kms_key_arn>
A402_EIF_SIGNING_CERT_SHA256=<sha256_of_eif_signing_certificate_der_or_pem_bytes>
A402_ATTESTATION_PROTOCOL=a402-svm-v1

# TLS terminates inside the enclave
A402_ENCLAVE_TLS_CERT_PATH=/etc/a402/tls/server.crt
A402_ENCLAVE_TLS_KEY_PATH=/etc/a402/tls/server.key
# Optional mTLS:
# A402_ENCLAVE_TLS_CLIENT_CA_PATH=/etc/a402/tls/client-ca.crt

# Optional ops flags; keep both disabled for public deploys unless you need a smoke window
A402_ENABLE_PROVIDER_REGISTRATION_API=0
A402_ENABLE_ADMIN_API=0
# Required when either control-plane API above is enabled. Prefer the SHA-256
# hash in enclave env; keep the raw token only on the operator/client side.
# A402_ADMIN_AUTH_TOKEN_SHA256=<sha256_of_admin_bearer_token>

# Batch privacy defaults for public deployments
A402_BATCH_WINDOW_SEC=120
A402_MIN_BATCH_PROVIDERS=2
A402_MIN_ANONYMITY_WINDOW_SEC=300
A402_AUTO_BATCH_MIN_PROVIDER_PAYOUT_ATOMIC=1000000
# Only set to 1 for an explicit one-off demo smoke; keep 0 for public runtime.
A402_ALLOW_ADMIN_PRIVACY_BYPASS_BATCH=0
